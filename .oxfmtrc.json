{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "singleQuote": true,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".next",
    "node_modules",
    ".yarn",
    "dist",
    "storybook-static",
    ".pnp",
    ".pnp.js",
    "coverage",
    "pnpm-lock.yaml",
    "package-lock.json",
    "yarn.lock",
    "*.log*",
    ".DS_Store",
    "*.pem",
    ".changeset/*.md"
  ]
}
